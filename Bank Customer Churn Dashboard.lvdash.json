      "displayName": "dim_geography",
      "queryLines": [
        "SELECT * FROM churn_catalog.gold.dim_geography"
      ]
    },
    {
      "name": "c5d939b9",
      "displayName": "fact_customer_churn",
      "queryLines": [
        "SELECT * FROM churn_catalog.gold.fact_customer_churn"
      ]
    },
    {
      "name": "fde091b8",
      "displayName": "dim_product",
      "queryLines": [
        "SELECT * FROM churn_catalog.gold.dim_product"
      ]
    },
    {
      "name": "9a8e7f05",
      "displayName": "customer_count_by_country",
      "queryLines": [
        "SELECT \r\n",
        "    g.country,\r\n",
        "    COUNT(f.customer_id) AS total_customers\r\n",
        "FROM churn_catalog.gold.fact_customer_churn f\r\n",
        "JOIN churn_catalog.gold.dim_geography g\r\n",
        "ON f.geo_id = g.geo_id\r\n",
        "GROUP BY g.country\r\n",
        "ORDER BY total_customers DESC;"
      ]
    },
    {
      "name": "2a8a6724",
      "displayName": "avg_balance_by_product_usage",
      "queryLines": [
        "SELECT\r\n",
        "p.product_usage_level,\r\n",
        "AVG(f.balance) AS avg_balance\r\n",
        "FROM dim_product p\r\n",
        "JOIN fact_customer_churn f\r\n",
        "ON p.product_id = f.product_id\r\n",
        "GROUP BY p.product_usage_level;"
      ],
      "catalog": "churn_catalog",
      "schema": "gold"
    },
    {
      "name": "e37be45a",
      "displayName": "customer_activity_analysis",
      "queryLines": [
        "SELECT \r\n",
        "    CASE \r\n",
        "        WHEN a.is_active_member = 1 THEN 'Active Customers'\r\n",
        "        ELSE 'Inactive Customers'\r\n",
        "    END AS customer_status,\r\n",
        "    COUNT(f.customer_id) AS customers\r\n",
        "FROM churn_catalog.gold.fact_customer_churn f\r\n",
        "JOIN churn_catalog.gold.dim_activity a\r\n",
        "ON f.activity_id = a.activity_id\r\n",
        "GROUP BY customer_status;"
      ]
    },
    {
      "name": "8f788a36",
      "displayName": "financial_behavior_analysis",
      "queryLines": [
        "SELECT\r\n",
        "    'Average Credit Score' AS metric,\r\n",
        "    AVG(credit_score) AS value\r\n",
        "FROM churn_catalog.gold.fact_customer_churn\r\n",
        "\r\n",
        "UNION ALL\r\n",
        "\r\n",
        "SELECT\r\n",
        "    'Average Balance' AS metric,\r\n",
        "    AVG(balance) AS value\r\n",
        "FROM churn_catalog.gold.fact_customer_churn;"
      ]
    }
  ],
